{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node", "react", "react-dom"],
    "skipLibCheck": true,
    "strict": false,
    "useDefineForClassFields": true
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "src/**/*.d.ts", "api/**/*.js", "server/**/*.js", "vite.config.js"],
  "exclude": ["dist", "node_modules", "AutoFlow", "tests"]
}
