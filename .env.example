FINANCIAL_DATA_PROVIDER=auto

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Lean KSA Open Banking. Keep LEAN_CLIENT_SECRET on the server only.
LEAN_ENV=sandbox
LEAN_APPLICATION_ID=
LEAN_CLIENT_SECRET=
LEAN_APP_TOKEN=
LEAN_APP_USER_ID=autoflow-sandbox-user
# Optional stable IDs. Production should store these per authenticated user in a database.
LEAN_CUSTOMER_ID=
LEAN_ENTITY_ID=
OPENAI_API_KEY=
OPENAI_AUTOMATION_MODEL=gpt-5.6-terra
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=cedar
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_NOISE_REDUCTION=far_field
